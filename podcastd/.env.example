# podcastd configuration

# LLM
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:32b
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Uncomment for Anthropic instead:
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_API_KEY=sk-ant-...

# ComfyUI
COMFYUI_BASE_URL=http://comfyui:8188

# Voice seeds — run calibrate.py, pick your favorites, set here
VOICE_SEED_A=42
VOICE_SEED_B=137

# VibeVoice models
CHUNK_MODEL=Large
INTERRUPT_MODEL=1.5B

# Ollama Web Search (enriches interrupt responses with live web data)
# Get your API key at https://ollama.com/settings/keys
OLLAMA_API_KEY=
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5

# Domain (used by Traefik)
INTERNAL_DOMAIN=deepread.fm
